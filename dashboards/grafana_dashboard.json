{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "title": "Prediction Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(prediction_count_total[5m])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Prediction Latency p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Fraud Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(prediction_count_total{label=\"true\"}[5m])) / sum(rate(prediction_count_total[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Model Version",
      "type": "stat",
      "targets": [
        {
          "expr": "model_version_info",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 5,
      "title": "Drift Score",
      "type": "timeseries",
      "targets": [
        {
          "expr": "drift_score",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 6,
      "title": "API Up",
      "type": "stat",
      "targets": [
        {
          "expr": "up{job=\"fraud-serving-api\"}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["fraud", "mlops", "monitoring"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Fraud Detection Observability Dashboard",
  "version": 1
