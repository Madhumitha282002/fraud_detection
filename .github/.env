PROJECT_NAME=fraud_detection
ENVIRONMENT=dev

KAFKA_BROKERS=kafka:9092
KAFKA_RAW_TOPIC=transactions
KAFKA_PROCESSED_TOPIC=processed-transactions
KAFKA_DLQ_TOPIC=transactions-dlq
KAFKA_GROUP_ID=fraud-feature-consumer

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_NAME=fraud-detection-model

REDIS_HOST=redis
REDIS_PORT=6379

FEAST_REPO_PATH=src/feature_engineering/feature_store

SERVING_HOST=0.0.0.0
SERVING_PORT=8000

AIRFLOW_BASE_URL=http://localhost:8080/api/v1
